	<parameter name="StartDate" class="java.util.Date">
		<description><![CDATA[Crystal {?StartDate} / formula StartDate]]></description>
	</parameter>
	<parameter name="EndDate" class="java.util.Date">
		<description><![CDATA[Crystal {?EndDate} / formula EndDate]]></description>
	</parameter>
	<parameter name="PayDate" class="java.util.Date">
		<description><![CDATA[Crystal {?PayDate} / formula PayDate]]></description>
		<defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT
  I.BANKACCOUNTNAME,
  I.BANKACCOUNTNO,
  I.BANKREF,
  I.BANKSORTCODE,
  I.IFA_REF,
  I.NETWORKIFAREFERENCE,
  I.PAIDBYBACS,
  N.BANKSORTCODE AS NET_BANKSORTCODE,
  N.BANKACCOUNTNO AS NET_BANKACCOUNTNO,
  N.BANKACCOUNTNAME AS NET_BANKACCOUNTNAME,
  N.BANKREF AS NET_BANKREF,
  N.PAIDBYBACS AS NET_PAIDBYBACS,
  P.ADVISER_CHARGE_AMT,
  P.COMMISSION,
  P.COMPLETION
FROM reports.PADETAIL P
INNER JOIN reports.IFA I ON I.IFA_REF = P.IFA_REF
LEFT JOIN reports.IFANET N ON N.IFA_REF = TRIM(I.NETWORKIFAREFERENCE)
WHERE  I.PAIDBYBACS = 'Y'
  AND   P.COMPLETION >= $P{StartDate}
  AND P.COMPLETION < ($P{EndDate}::timestamp + INTERVAL '1 day')
  AND COALESCE(P.COMMISSION, 0) <> 0
ORDER BY
  CASE
    WHEN I.NETWORKIFAREFERENCE IS NULL THEN I.IFA_REF
    WHEN I.NETWORKIFAREFERENCE <> 'IFA P-001' THEN I.NETWORKIFAREFERENCE
    ELSE I.IFA_REF
  END,
  I.IFA_REF]]></query>
