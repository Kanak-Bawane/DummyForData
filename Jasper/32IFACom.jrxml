	</variable>
	<variable name="IFREF" resetType="Group" calculation="First" resetGroup="IFREFGroup" class="java.lang.String">
		<expression><![CDATA[$F{networkifareference} == null
    ? $F{ifa_ref}
    : (!"IFA P-001".equals($F{networkifareference}) ? $F{networkifareference} : $F{ifa_ref})]]></expression>
	</variable>
	<variable name="Decider" resetType="Group" calculation="First" resetGroup="IFREFGroup" class="java.lang.String">
		<expression><![CDATA[$F{networkifareference}== null
    ? (!"Y".equals($V{PBB}) ? "1" : "2")
    : (!"IFA P-001".equals($F{networkifareference})
        ? (!"Y".equals($V{NetPBB}) ? "3" : "4")
        : (!"Y".equals($V{PBB}) ? "1" : "2"))]]></expression>
	</variable>
	<variable name="sortCodeRaw" resetType="Group" calculation="First" resetGroup="IFREFGroup" class="java.lang.String">
		<expression><![CDATA["2".equals($V{Decider}) ? $F{banksortcode} :$F{net_banksortcode}]]></expression>
	</variable>
	<variable name="SortCode" resetType="Group" calculation="First" resetGroup="IFREFGroup" class="java.lang.String">
		<expression><![CDATA[$V{sortCodeRaw} == null || $V{sortCodeRaw}.length() < 6
    ? ($V{sortCodeRaw} == null ? "" : $V{sortCodeRaw})
    : $V{sortCodeRaw}.substring(0, 2) + "-" + $V{sortCodeRaw}.substring(2, 4) + "-" + $V{sortCodeRaw}.substring(4, 6)]]></expression>
	</variable>
	<variable name="BankAccountName" resetType="Group" calculation="First" resetGroup="IFREFGroup" class="java.lang.String">
		<expression><![CDATA["2".equals($V{Decider}) ? $F{bankaccountname} : $F{net_bankaccountname}]]></expression>
	</variable>
	<variable name="BankAccountNo" resetType="Group" calculation="First" resetGroup="IFREFGroup" class="java.lang.String">
		<expression><![CDATA["2".equals($V{Decider}) ? $F{bankaccountno} : $F{net_bankaccountno}]]></expression>
	</variable>
	<variable name="BankRef" resetType="Group" calculation="First" resetGroup="IFREFGroup" class="java.lang.String">
		<expression><![CDATA["2".equals($V{Decider}) ?$F{bankref} :$F{net_bankref}]]></expression>
	</variable>
	<variable name="ChargeAmtOrComm" resetType="Group" calculation="Sum" resetGroup="IFREFGroup" class="java.math.BigDecimal">
		<expression><![CDATA[$F{adviser_charge_amt} == null
    ? ($F{commission} == null ? java.math.BigDecimal.ZERO : $F{commission})
    :$F{adviser_charge_amt}]]></expression>
	</variable>
	<variable name="GrandChargeAmtOrComm" calculation="Sum" class="java.math.BigDecimal">
		<expression><![CDATA[$F{adviser_charge_amt}== null
    ? ($F{commission}== null ? java.math.BigDecimal.ZERO :$F{commission})
    : $F{adviser_charge_amt}]]></expression>
	</variable>
