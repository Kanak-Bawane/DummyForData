	<query language="SQL"><![CDATA[SELECT
  P.POLICY_NO,
  P.POLICY_REF,
  P.PREMIUM,
  P.COMMISSION,
  P.COMMISSIONPERCENT,
  P.ADVISER_CHARGE_AMT,
  P.ADVISER_CHARGE_PER,
  P.COMPLETION,
  P.PH_CORRESPOND_NAME,
  P.PH_SHORT_NAME,
  P.SURNAME_1,
  P.FORENAME_A_1,
  P.FORENAME_B_1,
  P.PH_ADDRESS_1,
  P.PH_ADDRESS_2,
  P.PH_ADDRESS_3,
  P.PH_ADDRESS_4,
  P.PH_ADDRESS_5,
  P.PH_POST_CODE,
  P.PLANTYPE,
  C.ANN_ADDRESS_1,
  C.ANN_ADDRESS_2,
  C.ANN_ADDRESS_3,
  C.ANN_ADDRESS_4,
  C.ANN_ADDRESS_5,
  C.ANN_POST_CODE,
  I.IFA_REF,
  I.NETWORKIFAREFERENCE,
  I.PARTNER_CODE,
  I.BROKER_NAME,
  I.BUILDING,
  I.NO_STREET,
  I.DISTRICT,
  I.CITY,
  I.COUNTY,
  I.POST_CODE,
  I.TEL,
  I.PAIDBYBACS,
  I.BANKSORTCODE,
  I.BANKACCOUNTNO,
  I.BANKACCOUNTNAME,
  I.BANKREF,
  N.IFA_REF AS NET_IFA_REF,
  N.BROKER_NAME AS NET_BROKER_NAME,
  N.BUILDING AS NET_BUILDING,
  N.NO_STREET AS NET_NO_STREET,
  N.DISTRICT AS NET_DISTRICT,
  N.CITY AS NET_CITY,
  N.COUNTY AS NET_COUNTY,
  N.POST_CODE AS NET_POST_CODE,
  N.TEL AS NET_TEL,
  N.PAIDBYBACS AS NET_PAIDBYBACS,
  N.BANKSORTCODE AS NET_BANKSORTCODE,
  N.BANKACCOUNTNO AS NET_BANKACCOUNTNO,
  N.BANKACCOUNTNAME AS NET_BANKACCOUNTNAME,
  N.BANKREF AS NET_BANKREF
FROM reports.PADETAIL P
INNER JOIN reports.IFA I ON I.IFA_REF = P.IFA_REF
LEFT JOIN reports.IFANET N ON N.IFA_REF = TRIM(I.NETWORKIFAREFERENCE)
LEFT JOIN reports.CONTACTS C ON C.POLICY_NO = P.POLICY_NO
WHERE I.PAIDBYBACS = 'Y'
  AND P.COMPLETION >= $P{StartDate}
  AND P.COMPLETION < ($P{EndDate}::timestamp + INTERVAL '1 day')
ORDER BY
  CASE
    WHEN I.NETWORKIFAREFERENCE IS NULL OR TRIM(I.NETWORKIFAREFERENCE) = '' THEN I.IFA_REF
    WHEN TRIM(I.NETWORKIFAREFERENCE) <> 'IFA P-001' THEN TRIM(I.NETWORKIFAREFERENCE)
    ELSE I.IFA_REF
  END,
  I.IFA_REF,
  P.POLICY_REF]]></query>
