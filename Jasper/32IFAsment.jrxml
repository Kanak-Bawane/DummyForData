	<variable name="PBB" class="java.lang.String">
		<expression><![CDATA[$F{paidbybacs} == null ? "NULL" : $F{paidbybacs}.trim().toUpperCase()]]></expression>
	</variable>
	<variable name="NetPBB" class="java.lang.String">
		<expression><![CDATA[$F{net_paidbybacs} == null ? "NULL" : $F{net_paidbybacs}.trim().toUpperCase()]]></expression>
	</variable>
	<variable name="GroupKey" class="java.lang.String">
		<expression><![CDATA[($F{networkifareference} == null || $F{networkifareference}.trim().isEmpty())
    ? $F{ifa_ref}
    : (!"IFA P-001".equals($F{networkifareference}.trim()) ? $F{networkifareference}.trim() : $F{ifa_ref})]]></expression>
	</variable>
	<variable name="Decider" class="java.lang.String">
		<expression><![CDATA[($F{networkifareference} == null || $F{networkifareference}.trim().isEmpty())
    ? (!"Y".equals($V{PBB}) ? "1" : "2")
    : (!"IFA P-001".equals($F{networkifareference}.trim())
        ? (!"Y".equals($V{NetPBB}) ? "3" : "4")
        : (!"Y".equals($V{PBB}) ? "1" : "2"))]]></expression>
	</variable>
	<variable name="IFA_REF" class="java.lang.String">
		<expression><![CDATA["2".equals($V{Decider})
    ? ($F{ifa_ref} == null ? "" : $F{ifa_ref})
    : ($F{net_ifa_ref} == null ? "" : $F{net_ifa_ref})]]></expression>
	</variable>
	<variable name="BrokerName" class="java.lang.String">
